---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import BaseHead from "../components/BaseHead.astro";
import { SITE_TITLE, AUTHOR, SITE_DESCRIPTION, CONTACT_FORM_URL } from "../consts";
import Cases from "../components/Cases.tsx";

const services = [
  {
    "title": "Artificial Intelligence",
    "href": "artificial-intelligence",
    "image": "/service-ai.jpg",
    "subtitle": "AI-Powered Solutions",
    "list": [
      "AI Integration (ChatGPT, Gemini, DeepSeek)",
      "Chatbots and Conversational AI",
      "Multi-Agent Systems",
      "Model Customization (RAG & Fine-Tuning)"
    ],
    "description": "I help businesses leverage artificial intelligence to automate processes, extract insights from data, and build intelligent digital products. From AI-powered features to full AI integrations, I design practical solutions that deliver real business value."
  },
  {
    "title": "Software Development",
    "href": "software-development",
    "image": "/service-software.jpg",
    "subtitle": "Scalable Applications & Automation",
    "list": [
      "SaaS Applications",
      "REST API Development",
      "Process Automation",
      "Microservices Architecture",
      "System Architecture & Design",
      "E-commerce Platforms"
    ],
    "description": "I design and build scalable digital products, including web applications, SaaS platforms, and backend systems. My focus is on clean architecture, performance, and reliability to ensure your software is maintainable and ready to scale as your business grows."
  },
  {
    "title": "Data",
    "href": "data",
    "image": "/service-data.jpg",
    "subtitle": "Raw data to insights",
    "list": [
      "Data Pipelines and Processing",
      "Data Collection (SQL & NoSQL Databases)",
      "Data Analysis with AI-Driven Insights",
      "Data Visualization (Dashboards with Metrics and KPIs)"
    ],
    "description": "Let’s transform raw data into actionable insights through reliable data pipelines, analysis, and visualization. By structuring and processing data effectively, I help teams monitor performance, uncover opportunities, and make better data-driven decisions."
  }
];

const logos = ["/logo-hypera.svg", "/logo-mantecorp.svg", "/logo-cocari.svg", "/logo-vg.svg", "/logo-smartfit.svg"];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE + " - " + SITE_DESCRIPTION} description={SITE_DESCRIPTION} />
	</head>
	<body class="min-h-screen flex flex-col">
		<Nav />

		<header class="bg-[#DDEFFF] min-h-[70vh] py-8 bg-[url(/hero.png)] bg-bottom bg-no-repeat">
			
			<div class="text-center flex flex-col gap-2">
				<h1 class="text-3xl font-bold">{AUTHOR}</h1>
				<article>
					{services.map(i => {
						return (
							<span class="uppercase px-1 text-sm">{i.title}</span>
						)
					})}
				</article>
				<div>
					<a href="#services" class="bg-black !text-white p-2 hover:bg-white hover:!text-black rounded-xs transition">Empowering bussinesses through technology</a>
				</div>
			</div>

		</header>

		<section id="clients" class="p-4 bg-[#0092FF] -mt-1">
			<ul class="flex items-center justify-center gap-4 space-x-1 md:space-x-8">
				{logos.map(logo => {
					return (
						<li>
							<img src={logo} alt="Logo" class="w-full h-full object-contain max-h-10 max-w-40" />
						</li>
					)
				})}
			</ul>
		</section>

		<main class="flex-1">
			<div class="container mx-auto px-2 py-8">

				<section id="services" class="pt-8 pb-20">
					<h2 class="text-2xl font-bold text-center uppercase mb-8">
						Services & Solutions
					</h2>
					<ul class="flex flex-col gap-16">
						{
							services.map((service) => (
								<li class="flex flex-col items-start md:items-center gap-4 md:flex-row even:md:flex-row-reverse">
									<div class="flex-1">
										<img
											src={service.image}
											alt={service.title}
											class="w-full h-full object-cover"
										/>
									</div>
									<div class="flex-1 flex flex-col gap-2 p-2">
										<a href={`/services/#${service.href}`} class="uppercase">{service.title}</a>
										<p class="text-2xl font-bold">{service.subtitle}</p>
										<ul class="list-disc list-inside">
											{service.list.map((item) => (
												<li>{item}</li>
											))}
										</ul>
										{/* <p>{service.description}</p> */}
									</div>
								</li>
							))
						}
					</ul>
				</section>

				<section id="cases" class="py-20 flex items-center justify-center">
					<div>
						<h2 class="text-2xl font-bold text-center uppercase mb-4">Cases</h2>
						<Cases client:load />
					</div>
				</section>

				<section id="about" class="py-20 lg:px-52 flex items-center justify-center">
					
					<div> 
						<div>
							<h2 class="text-2xl font-bold text-center uppercase mb-4">ABOUT ME</h2>
						<div>
							
						<div class="flex flex-col items-center gap-4 md:flex-row-reverse">
							<div class="flex-1">
								<img src="/profile.jpg" alt="About Me" class="aspect-square object-cover object-top rounded-full w-full h-full" />
							</div>
							<article class="flex-1 flex flex-col gap-4">
								<h3 class="text-3xl font-bold">
									<span class="bg-black text-white px-3 py-2">I'm Ian</span>
								</h3>
								<p>I’m a Brazilian software engineer with 8 years of experience building applications from scratch to production.</p>
								<p>I primarily work with Python, TypeScript, Java, SQL, Docker, and AWS, developing full-stack solutions, APIs, and scalable microservices.</p>
								<p>I hold a degree in Information Technology and speak both English and Portuguese.</p>
								<p><a href="#contact">Get in touch</a> and let’s work together.</p>
							</article>
						</div>
					</div>

				</section>

				<section id="contact" class="flex items-center justify-center py-12">
					<div class="w-full flex flex-col items-center gap-4">
						<div class="text-center flex flex-col items-center gap-2">
							<h2 class="text-2xl font-bold text-center uppercase">GET IN TOUCH</h2>
							<p>Fill out the form or feel free to send a message on <a href="https://www.linkedin.com/in/ianify" target="_blank">LinkedIn</a></p>
						</div>
						<form id="contact-form" action={CONTACT_FORM_URL} method="POST" class="flex flex-col items-center gap-4 w-full">
							<div class="flex flex-col gap-2 w-full">
							  <label for="name" class="text-left">Name</label>
							  <input type="text" name="name" placeholder="John Doe" required class="w-full p-2 border border-gray-300 rounded-xs" />
							</div>
							<div class="flex flex-col gap-2 w-full">
							  <label for="email" class="text-left">Email</label>
							  <input type="email" name="email" placeholder="email@example.com" required class="w-full p-2 border border-gray-300 rounded-xs" />
							</div>
							<div class="flex flex-col gap-2 w-full">
							  <label for="message" class="text-left">Message</label>
							  <textarea name="message" placeholder="Write your message here." rows="10" required class="w-full p-2 border border-gray-300 rounded-xs"></textarea>
							</div>
							<button id="contact-submit" type="submit" class="w-full p-2 bg-accent text-white rounded-xs cursor-pointer">Send your message</button>
							<span class="hidden !bg-gray-500"></span>
						  </form>
					</div>
				</section>

			</div>
		</main>
		<Footer />
		<script>
			if (typeof window !== "undefined") {
				window.addEventListener("DOMContentLoaded", () => {
					const form = document.getElementById("contact-form") as HTMLFormElement | null;
					if (!form) return;

					const submitButton = form.querySelector("button[type='submit']") as HTMLButtonElement | null;
					if (!submitButton) return;

					const defaultLabel = submitButton.textContent || "Send your message";

					form.addEventListener("submit", async (event) => {
						event.preventDefault();

						submitButton.disabled = true;
						submitButton.textContent = "Sending...";
						submitButton.classList.remove("bg-accent");
						submitButton.classList.add("!bg-gray-500");

						const data = new FormData(form);

						try {
							const response = await fetch(form.action, {
								method: form.method,
								body: data,
							});

							if (response.ok) {
								submitButton.textContent = "Message sent";
								form.reset();
							} else {
								submitButton.disabled = false;
								submitButton.textContent = defaultLabel;
								submitButton.classList.remove("!bg-gray-500");
								submitButton.classList.add("bg-accent");
							}
						} catch (error) {
							submitButton.disabled = false;
							submitButton.textContent = defaultLabel;
							submitButton.classList.remove("!bg-gray-500");
							submitButton.classList.add("bg-accent");
						}
					});
				});
			}
		</script>
	</body>
</html>

