---
import NavLink from './NavLink.astro';
import { SITE_TITLE } from '../consts';
import { NAV_LINKS } from '../consts';
import { SOCIAL_LINKS } from '../consts';
---

<header class="bg-gray-200">
	<div class="container mx-auto px-2 py-4">
		<nav class="flex justify-between items-center gap-4">
			<h2 class="text-2xl font-bold"><a href="/">{SITE_TITLE}</a></h2>
			<div class="flex justify-center gap-4">
				{
					NAV_LINKS.map((item) => (
						<NavLink href={item.href}>{item.label}</NavLink>
					))
				}
			</div>
			<div class="flex justify-center gap-4 hidden md:flex">
				{
					SOCIAL_LINKS.map((item) => (
						<a href={item.href} target="_blank">
							<span class="sr-only">{item.alt}</span>
							<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon={item.astroIcon}>
								<path fill="currentColor" d={item.d} />
							</svg>
						</a>
					))
				}
			</div>
	</div>
	</nav>
</header>